generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Asset {
  id                  Int      @id @default(autoincrement())
  symbol              String   @unique
  name                String
  category            String
  consensus           String
  energyPerTx         Float
  teamTransparency    String
  launchYear          Int
  audited             Boolean
  auditor             String?
  marketCap           Float
  githubActivity      String
  legitimacyScore     Int
  sustainabilityScore Int
  exchangeListing     String
  tokenDistribution   String
  githubCommits       String
  sustainabilityNotes String
  redFlags            String
  description         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Portfolio {
  id              Int      @id @default(autoincrement())
  selected        String
  strategy        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
